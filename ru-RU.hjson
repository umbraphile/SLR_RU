					'''
			}

			VitricBossBarrierDye: {
				DisplayName: Настойка стража
				Tooltip:
					'''
					Заставляет барьер имитировать щит Расколотого Стража
					Можно надеть
					Предмет украшения
					'''
			}

			SeaglassRing: {
				DisplayName: Кольцо морского стекла
				Tooltip:
					'''
					+10 барьера
					Bосстановление барьера начинается немного раньше
					'Избивающие волны не ослабили его сияние'
					'''
			}

			BreachCannon: {
				DisplayName: Нарушающая пушка
				Tooltip:
					'''
					Призывает турель, стреляющую лазерами в сторону курсора 
					Эти лазеры могут объединяться
					'''
			}

			BreacherChest: {
				DisplayName: Нагрудник нарушителя
