					'''
			}

			TestWhipImprint: {
				DisplayName: "[PH]Тестовый хлыст"
				Tooltip: Без эффекта
			}

			Astral: {
				DisplayName: Рывок кометы I
				Tooltip:
					'''
					Насыщение запретных ветров
					Делайте рывок дальше, удерживая бóльшую скорость
					Повышает затраты звёздного сияния на 1.3
					'''
			}

			Astral2: {
				DisplayName: Рывок кометы II
				Tooltip:
					'''
					Насыщение запретных ветров
					Делайте рывок дальше, удерживая ещё бóльшую скорость
					Повышает затраты звёздного сияния на 1.6
					'''
			}

			Astral3: {
				DisplayName: Рывок кометы III
				Tooltip:
					'''
					Насыщение запретных ветров
					Делайте рывок дальше, удерживая наибольшую скорость
					Повышает затраты звёздного сияния на 2
					'''
			}

			AstralImprint: {
				DisplayName: Рывок кометы
				Tooltip: Делайте рывок дальше, удерживая бóльшую скорость
			}

			Blink: {
				DisplayName: Телепорт
				Tooltip:
					'''
					Насыщение запретных ветров
					Мгновенно телепортируйтесь на небольшое расстояние вперед, игнорируя врагов и их атаки
					'''
			}

			BlinkImprint: {
				DisplayName: Телепорт
				Tooltip: Мгновенно телепортируйтесь на небольшое расстояние вперед, игнорируя врагов и их атаки
			}

			Pulse: {
				DisplayName: Импульс
				Tooltip:
					'''
					Насыщение запретных ветров
					Рывок заменён коротким, частым и мощным всплеском скорости
					Понижает затраты звёздного сияния на 0.25
					'''
			}

			PulseImprint: {
				DisplayName: Импульс
				Tooltip: Рывок заменен коротким, частым и мощным всплеском скорости
			}

			BasicInfusion: {
				DisplayName: Пустой сланец
				Tooltip:
					'''
					Может быть помечен испытаниями на станции насыщения
					Выполняйте испытания, чтобы превратить в насыщение
					По мере вашего прохождения, будут открываться новые насыщения
					'''
			}

			CauldronItem: {
				Tooltip: Устанавливает алхимический котёл
				DisplayName: Котёл
			}

			MixingStick: {
				Tooltip:
					'''
					Палочка для перемешивания 
