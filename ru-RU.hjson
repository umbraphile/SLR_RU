			}

			BreacherHead: {
				DisplayName: Визор нарушителя
				Tooltip: Увеличивает урон стрелкового критического удара на 15%
			}

			BreacherLegs: {
				DisplayName: Поножи нарушителя
				Tooltip: Увеличивает урон стрелкового критического удара до 20%, в зависимости от вашей скорости передвижения
			}

			FlareBreacher: {
				DisplayName: Сигнальная ракета нарушителя
				Tooltip: Стреляет взрывающимися сигнальными ракетами, которые, вонзившись в цели, взрываются осколками сквозь них и за ними
			}

			ReactivePlating: {
				DisplayName: Реактивное покрытие
				Tooltip:
					'''
					Получите небольшое сопротивление урону после получения нескольких ударов
					'Защита активируется, но только после... повторных раздражений.'
					'''
			}

			ScrappodItem: {
				DisplayName: Капсула с металлоломом
				Tooltip: Разбивается на осколки, когда достигает курсора
			}

			Scrapshot: {
				DisplayName: Мусорострел
				Tooltip:
					'''
					Нажмите <right>, чтобы притянуть врагов крюком
					Стреляйте, пока враг на крюке, чтобы понизить разброс и отправиться в полёт
